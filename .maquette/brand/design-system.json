      "worktrees",
      "ignored files",
      "CLI",
      "copy",
      "dry-run",
      "safety"
    ],
    "constraints": [
      "No generated logo, wordmark, mascot, app icon, badge, seal, monogram, or trademark-like brand mark in the brand kit.",
      "Support light and dark modes.",
      "Use the odor/air-current joke sparingly so the page remains useful documentation.",
      "Keep hierarchy compact enough that quick-start documentation is visible early."
